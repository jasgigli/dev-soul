{
  "name": "dev-soul",
  "version": "0.6.0",
  "description": "A portable developer environment doctor, setup assistant, and quality gate for Backend projects.",
  "type": "commonjs",
  "main": "src/index.js",
  "bin": {
    "dev-soul": "bin/dev-soul.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node scripts/check-syntax.js",
    "build": "node bin/dev-soul.js --version",
    "doctor": "node bin/dev-soul.js doctor",
    "doctor:strict": "node bin/dev-soul.js doctor --strict",
    "doctor:json": "node bin/dev-soul.js doctor --json",
    "score": "node bin/dev-soul.js score",
    "ready": "node bin/dev-soul.js ready",
    "plan": "node bin/dev-soul.js plan",
    "audit:package": "node bin/dev-soul.js audit",
    "prepare:local": "npm pack --dry-run"
  },
  "keywords": [
    "developer-tooling",
    "node",
    "cli",
    "project-health",
    "internal-tool",
    "ci",
    "quality"
  ],
  "author": "Junaid Ali Shah <overview.jjj@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jasgigli/devai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasgigli/devai.git"
  },
  "bugs": {
    "url": "https://github.com/jasgigli/devai/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
